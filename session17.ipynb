        "# Example distance of new node to goal\n",
        "distance_to_goal = 0.3   # meters\n",
        "goal_radius = 0.4\n",
        "\n",
        "# Check goal connection\n",
        "if distance_to_goal <= goal_radius:\n",
        "    result = \"Goal Connected\"\n",
        "else:\n",
        "    result = \"Not Connected\"\n",
        "\n",
        "# Output\n",
        "print(result)"
      ]
    }
