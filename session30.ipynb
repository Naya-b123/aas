      "source": [
        "# Input values\n",
        "desired = 0.5\n",
        "actual = 0.2\n",
        "\n",
        "# Wall-following logic\n",
        "if actual < desired:\n",
        "    action = \"Move Away from Wall\"\n",
        "elif actual > desired:\n",
        "    action = \"Move Toward Wall\"\n",
        "else:\n",
        "    action = \"Maintain Distance\"\n",
        "\n",
        "# Output\n",
        "print(\"Action:\", action)"
      ]
    }
  ]
}