        "# Inputs\n",
        "obstacle = True\n",
        "speed = 5   # > 0\n",
        "\n",
        "# Rule-based decision\n",
        "if obstacle and speed > 0:\n",
        "    action = \"Stop\"\n",
        "else:\n",
        "    action = \"Move\"\n",
        "\n",
        "# Output\n",
        "print(\"Action:\", action)"
      ]
