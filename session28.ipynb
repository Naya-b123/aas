        "# Input values\n",
        "distance = 0.25\n",
        "threshold = 0.5\n",
        "\n",
        "# Obstacle avoidance logic\n",
        "if distance < threshold:\n",
        "    action = \"Turn Right\"\n",
        "else:\n",
        "    action = \"Move Forward\"\n",
        "\n",
        "# Output\n",
        "print(\"Action:\", action)"
      ]
