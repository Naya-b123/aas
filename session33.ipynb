      "source": [
        "import random\n",
        "\n",
        "# Current direction (degrees)\n",
        "direction = 0\n",
        "\n",
        "# Random angle (example: 90)\n",
        "angle = 90\n",
        "\n",
        "# Update direction\n",
        "direction = (direction + angle) % 360\n",
        "\n",
        "print(\"New Direction:\", direction, \"degrees\")\n",
        "print(\"Direction Updated\")"
      ]
    }
  ]
