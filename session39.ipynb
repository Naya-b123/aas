      "source": [
        "# Example orientation (degrees)\n",
        "orientation = 45.0\n",
        "\n",
        "# Measured drift\n",
        "drift = 1.8\n",
        "\n",
        "# Correct orientation\n",
        "corrected_orientation = orientation - drift\n",
        "\n",
        "print(\"Corrected Orientation:\", corrected_orientation)\n",
        "print(\"Orientation Stabilized\")"
      ]
    }
  ]
