        "# Offset from center (pixels)\n",
        "offset = 25\n",
        "\n",
        "# Line-following logic\n",
        "if offset > 0:\n",
        "    action = \"Turn Left\"\n",
        "elif offset < 0:\n",
        "    action = \"Turn Right\"\n",
        "else:\n",
        "    action = \"Go Straight\"\n",
        "\n",
        "# Output\n",
        "print(\"Action:\", action)"
      ]
