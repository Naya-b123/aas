        "# Input values\n",
        "time_taken = 95   # seconds\n",
        "time_limit = 100  # allowed time\n",
        "\n",
        "# Delivery check\n",
        "if time_taken <= time_limit:\n",
        "    result = \"Package Delivered\"\n",
        "else:\n",
        "    result = \"Delivery Failed\"\n",
        "\n",
        "# Output\n",
        "print(result)"
      ]
