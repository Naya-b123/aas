        "# Input values\n",
        "battery = 18   # percentage\n",
        "threshold = 20\n",
        "\n",
        "# Energy management logic\n",
        "if battery < threshold:\n",
        "    mode = \"Charging Mode\"\n",
        "else:\n",
        "    mode = \"Operating Mode\"\n",
        "\n",
        "# Output\n",
        "print(\"System Mode:\", mode)"
