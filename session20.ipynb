        "# Input values\n",
        "distance_to_goal = 0.15\n",
        "threshold = 0.2\n",
        "\n",
        "# Goal check\n",
        "if distance_to_goal < threshold:\n",
        "    result = \"Goal Reached\"\n",
        "else:\n",
        "    result = \"Moving Towards Goal\"\n",
        "\n",
        "# Output\n",
        "print(result)"
      ]
