      "source": [
        "import sympy as sp\n",
        "\n",
        "# Define variable\n",
        "x = sp.symbols('x')\n",
        "\n",
        "# Define function\n",
        "E = x**2 - 6*x + 10\n",
        "\n",
        "# Derivative\n",
        "dE_dx = sp.diff(E, x)\n",
        "\n",
        "# Solve derivative = 0\n",
        "min_point = sp.solve(dE_dx, x)\n",
        "\n",
        "print(\"Minimum Energy at x =\", min_point[0])"
      ]
    }
  ]
}