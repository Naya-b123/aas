      "source": [
        "# Wheel speeds\n",
        "left = 3\n",
        "right = 3\n",
        "\n",
        "# Motion decision\n",
        "if left == right:\n",
        "    motion = \"Straight Line Motion\"\n",
        "elif left > right:\n",
        "    motion = \"Turn Right\"\n",
        "else:\n",
        "    motion = \"Turn Left\"\n",
        "\n",
        "# Output\n",
        "print(\"Robot Motion:\", motion)"
      ]
    }
  ]
