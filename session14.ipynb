      "source": [
        "# Previous pose\n",
        "prev_pose = (2, 3)\n",
        "\n",
        "# Motion vector\n",
        "motion = (0.4, 0.6)\n",
        "\n",
        "# Compute new pose\n",
        "new_pose = (prev_pose[0] + motion[0], prev_pose[1] + motion[1])\n",
        "\n",
        "# Output\n",
        "print(\"New Pose:\", new_pose)"
      ]
    }
  ]
