      "source": [
        "# Simulated ROS2 publisher (no rclpy needed)\n",
        "\n",
        "import time\n",
        "\n",
        "rate = 15  # Hz\n",
        "delay = 1 / rate\n",
        "\n",
        "count = 0\n",
        "\n",
        "while count < 10:\n",
        "    print(f\"Publishing: Hello {count}\")\n",
        "    time.sleep(delay)\n",
        "    count += 1\n",
        "\n",
        "print(\"Real-Time Performance Achieved\")"
      ],
