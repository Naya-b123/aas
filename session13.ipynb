        "# Input values\n",
        "imu = 32       # degrees\n",
        "vision = 28    # degrees\n",
        "\n",
        "# Sensor fusion (mean)\n",
        "fused_angle = (imu + vision) / 2\n",
        "\n",
        "# Output\n",
        "print(\"Fused Angle:\", fused_angle, \"degrees\")"
      ]
