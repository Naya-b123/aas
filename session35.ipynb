        "# Given pose error\n",
        "pose_error = 0.08\n",
        "\n",
        "# Threshold\n",
        "threshold = 0.1\n",
        "\n",
        "# Localization check\n",
        "if pose_error < threshold:\n",
        "    result = \"Accurate Localization\"\n",
        "else:\n",
        "    result = \"Localization Error High\"\n",
        "\n",
        "# Output\n",
        "print(result)"
      ]
    }
