      "source": [
        "import math\n",
        "\n",
        "# Coordinates\n",
        "x1, y1 = 0, 0\n",
        "x2, y2 = 6, 8\n",
        "\n",
        "# Compute distance\n",
        "distance = math.sqrt((x2 - x1)**2 + (y2 - y1)**2)\n",
        "\n",
        "# Output\n",
        "print(\"Distance to Goal:\", distance, \"m\")"
      ]
    }
  ]
