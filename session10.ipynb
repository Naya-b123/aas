        "import math\n",
        "\n",
        "# Input values\n",
        "Gx = 5\n",
        "Gy = 12\n",
        "\n",
        "# Edge detection formula\n",
        "edge = math.sqrt(Gx**2 + Gy**2)\n",
        "\n",
        "# Output\n",
        "print(\"Edge Strength:\", edge)"
      ]
